    {
      "name": "Crear item",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// ✅ Validar status\r",
              "pm.test(\"Status 201 Created\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "// ✅ Convertir respuesta\r",
              "const response = pm.response.json();\r",
              "\r",
              "// ✅ Validar estructura\r",
              "pm.test(\"El item tiene ID\", function () {\r",
              "    pm.expect(response).to.have.property(\"_id\");\r",
              "});\r",
              "\r",
              "// ✅ Guardar ID automáticamente\r",
              "pm.collectionVariables.set(\"id\", response._id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
